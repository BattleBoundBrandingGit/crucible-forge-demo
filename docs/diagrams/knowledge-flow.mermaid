%% The Crucible — Knowledge Flow (the core loop)
flowchart LR
    W["Work<br/><i>converse · build · decide</i>"]
    C["Capture<br/><i>ambient, no note-taking</i>"]
    D["Distill<br/><i>structure · dedupe · type</i>"]
    K["Connect<br/><i>weave into the graph</i>"]
    R["Reuse<br/><i>auto-assembled context</i>"]

    W --> C --> D --> K --> R
    R -- "every session starts smarter" --> W

    style W fill:#FFF1E6,stroke:#EA580C
    style R fill:#FFF1E6,stroke:#EA580C
